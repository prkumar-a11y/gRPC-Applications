[Unit]
Description=Hello World gRPC Server
After=network.target

[Service]
Type=simple
User=grpc
WorkingDirectory=/opt/hello-world
ExecStart=/opt/hello-world/bin/server -port=50051 -tls -cert=/opt/hello-world/certs/server.crt -key=/opt/hello-world/certs/server.key
Restart=on-failure
RestartSec=10

# Security settings
NoNewPrivileges=true
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hello-world

[Install]
WantedBy=multi-user.target
